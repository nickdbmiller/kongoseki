{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "$docs": "https://code.claude.com/docs/en/settings",
    "autoMemoryEnabled": false,
    "autoUpdatesChannel": "stable",
    "claudeMdExcludes": [
        "**/kongoseki/mind/*",
        "~/.claude/*"
    ],
    "cleanupPeriodDays": 1,
    "env": {},
    "attribution": {
        "commit": "",
        "pr": ""
    },
    "includeGitInstructions": false,
    "respectGitignore": false,
    "permissions": {
        "allow": [
            "Bash(git diff *)",
            "Bash(git log *)",
            "Bash(git status *)",
            "Bash(ls*)",
            "Read(//mind/)"
        ],
        "ask": [
            "Bash",
            "Bash(cat:*)",
            "Bash(claude:*)",
            "Bash(docker:*)",
            "Bash(gh pr create:*)",
            "Bash(gh:*)",
            "Bash(git add:*)",
            "Bash(git commit:*)",
            "Bash(git:*)",
            "Bash(rm:*)",
            "Bash(source:*)",
            "WebSearch",
            "WebSearch(domain:medium.com)",
            "WebSearch(domain:stackoverflow.com)"
        ],
        "deny": [
            "Bash(*.sh)",
            "Bash(asdf:*)",
            "Bash(bash:*)",
            "Bash(brew:*)",
            "Bash(bundle:*)",
            "Bash(cask:*)",
            "Bash(curl:*)",
            "Bash(eval:*)",
            "Bash(exec:*)",
            "Bash(fastly:*)",
            "Bash(ftp:*)",
            "Bash(gem:*)",
            "Bash(heroku:*)",
            "Bash(irb:*)",
            "Bash(nc:*)",
            "Bash(npm:*)",
            "Bash(pg:*)",
            "Bash(psql:*)",
            "Bash(rails:*)",
            "Bash(rbenv:*)",
            "Bash(rm -rf:*)",
            "Bash(ruby:*)",
            "Bash(scp:*)",
            "Bash(sftp:*)",
            "Bash(ssh-:*)",
            "Bash(ssh:*)",
            "Bash(sudo:*)",
            "Bash(tap:*)",
            "Bash(telnet:*)",
            "Bash(thor:*)",
            "Bash(yarn:*)",
            "Read(*.dump)",
            "Read(*.env)",
            "Read(*.lock)",
            "Read(*.ssh)",
            "WebFetch",
            "WebSearch(domain:bsky.app)",
            "WebSearch(domain:facebook.com)",
            "WebSearch(domain:instagram.com)",
            "WebSearch(domain:quora.com)",
            "WebSearch(domain:reddit.com)",
            "WebSearch(domain:twitter.com)",
            "WebSearch(domain:x.com)"
        ],
        "defaultMode": "default",
        "disableBypassPermissionsMode": "disable",
        "disableAutoMode": "disable",
        "additionalDirectories": []
    },
    "language": "english",
    "model": "opus[1m]",
    "effortLevel": "high",
    "fastMode": false,
    "fastModePerSessionOptIn": true,
    "feedbackSurveyRate": 0,
    "enableAllProjectMcpServers": false,
    "enabledMcpjsonServers": [],
    "disabledMcpjsonServers": [],
    "allowedMcpServers": [],
    "deniedMcpServers": [],
    "httpHookAllowedEnvVars": [],
    "hooks": {
        "PreToolUse": [],
        "PostToolUse": [],
        "PostToolUseFailure": [],
        "PermissionRequest": [],
        "Notification": [],
        "UserPromptSubmit": [],
        "Stop": [],
        "StopFailure": [],
        "SubagentStart": [],
        "SubagentStop": [],
        "PreCompact": [],
        "PostCompact": [],
        "Elicitation": [],
        "ElicitationResult": [],
        "TeammateIdle": [],
        "TaskCompleted": [],
        "Setup": [],
        "InstructionsLoaded": [],
        "CwdChanged": [],
        "FileChanged": [],
        "ConfigChange": [],
        "WorktreeCreate": [],
        "WorktreeRemove": [],
        "SessionStart": [],
        "SessionEnd": []
    },
    "disableAllHooks": true,
    "allowedChannelPlugins": [],
    "allowedHttpHookUrls": [],
    "enabledPlugins": {},
    "extraKnownMarketplaces": {},
    "strictKnownMarketplaces": [],
    "skippedMarketplaces": [],
    "skippedPlugins": [],
    "outputStyle": "default",
    "skipWebFetchPreflight": false,
    "sandbox": {
        "enabled": false,
        "allowUnsandboxedCommands": false,
        "autoAllowBashIfSandboxed": false,
        "enableWeakerNestedSandbox": false,
        "enableWeakerNetworkIsolation": false,
        "excludedCommands": [
            "sudo"
        ],
        "filesystem": {},
        "ignoreViolations": {},
        "network": {}
    },
    "spinnerVerbs": {
        "mode": "replace",
        "verbs": [
            "Meditating",
            " ",
            "Washing bowls",
            "Pointing at the Moon",
            "Winding up for a slap"
        ]
    },
    "spinnerTipsEnabled": true,
    "spinnerTipsOverride": {
        "excludeDefault": true,
        "tips": [
            "Mu.",
            " ",
            "Is that so?",
            "Take up goat farming.",
            "Wash your bowls.",
            "Switching to your sidearm is faster than reloading."
        ]
    },
    "terminalProgressBarEnabled": true,
    "showTurnDuration": true,
    "prefersReducedMotion": true,
    "alwaysThinkingEnabled": false,
    "companyAnnouncements": [
        "Polishing the stone."
    ],
    "teammateMode": "auto",
    "pluginConfigs": {},
    "channelsEnabled": false,
    "defaultShell": "bash",
    "disableDeepLinkRegistration": "disable",
    "showClearContextOnPlanAccept": true,
    "showThinkingSummaries": true,
    "skipDangerousModePermissionPrompt": false,
    "tui": "fullscreen",
    "viewMode": "default",
    "useAutoModeDuringPlan": false,
    "voiceEnabled": false,
    "awaySummaryEnabled": false,
    "theme": "auto",
    "editorMode": "normal",
    "verbose": false,
    "preferredNotifChannel": "notifications_disabled",
    "autoCompactEnabled": false,
    "fileCheckpointingEnabled": true,
    "remoteControlAtStartup": false,
    "agentPushNotifEnabled": false
}