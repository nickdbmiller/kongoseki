{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "respectGitignore": true,
  "permissions": {
    "allow": [
      "Bash(git add:*)"
    ],
    "deny": [
      "Read(*.env)",
      "Bash(rm:*)",
      "Bash(curl:*)",
      "WebFetch"
    ],
    "ask": [
      "Bash(gh pr create:*)",
      "Bash(git commit:*)",
      "WebSearch"
    ],
    "defaultMode": "default"
  },
  "enableAllProjectMcpServers": false,
  "allowedMcpServers": [],
  "disableAllHooks": true,
  "enabledPlugins": {},
  "strictKnownMarketplaces": [],
  "language": "english",
  "autoUpdatesChannel": "stable"
}
